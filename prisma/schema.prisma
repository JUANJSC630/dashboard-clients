generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Platform {
  VERCEL
  RAILWAY
  NETLIFY
  RENDER
  HOSTINGER
  CLOUDFLARE
  HEROKU
  DIGITALOCEAN
  CUSTOM
}

enum SiteStatus {
  ACTIVE
  PAUSED
  DOWN
  MAINTENANCE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
  ONE_TIME
}

enum BillingStatus {
  PAID
  PENDING
  OVERDUE
}

enum Currency {
  USD
  COP
  EUR
  MXN
  ARS
  BRL
}

enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum IncidentType {
  ERROR
  DOWNTIME
  PERFORMANCE
  DEPLOYMENT
  BILLING
  REQUEST
  OTHER
}

enum IncidentUpdateStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Client {
  id               String   @id @default(uuid())
  userId           String
  firstName        String
  lastName         String
  email            String
  phone            String
  address          String?
  businessName     String?
  timezone         String?  @default("UTC")
  registrationDate DateTime @default(now())
  notes            String?  @db.Text

  sites    Site[]
  billings Billing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Site {
  id                String     @id @default(uuid())
  userId            String
  clientId          String
  name              String
  url               String
  platform          Platform   @default(CUSTOM)
  platformProjectId String?
  repositoryUrl     String?
  techStack         String?
  status            SiteStatus @default(ACTIVE)
  profileImage      String?    @db.Text
  description       String?    @db.Text
  lastCheckedAt    DateTime?
  uptimePercent    Float?
  checkIntervalMin Int       @default(5)
  sslExpiresAt     DateTime?
  sslDaysLeft      Int?

  contacts    Contact[]
  incidents   Incident[]
  billings    Billing[]
  statusLogs  SiteStatusLog[]
  pingLogs    SitePingLog[]
  alertConfig SiteAlertConfig?

  client Client @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([userId])
}

model SiteStatusLog {
  id        String     @id @default(uuid())
  siteId    String
  userId    String
  from      SiteStatus
  to        SiteStatus
  changedAt DateTime   @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
}

model Contact {
  id     String @id @default(uuid())
  siteId String

  name  String
  role  String
  email String
  phone String

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
}

model Billing {
  id          String        @id @default(uuid())
  userId      String
  siteId      String
  clientId    String
  amount      Float
  currency    Currency      @default(USD)
  cycle       BillingCycle  @default(MONTHLY)
  nextDueDate DateTime
  status      BillingStatus @default(PENDING)
  notes       String?       @db.Text

  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([clientId])
  @@index([userId])
}

model Incident {
  id          String           @id @default(uuid())
  userId      String
  siteId      String
  title       String
  description String?          @db.Text
  priority    IncidentPriority @default(MEDIUM)
  status      IncidentStatus   @default(OPEN)
  type        IncidentType     @default(OTHER)
  resolvedAt  DateTime?

  site    Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  updates IncidentUpdate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([userId])
}

model SitePingLog {
  id           String   @id @default(uuid())
  siteId       String
  isUp         Boolean
  statusCode   Int?
  latencyMs    Int?
  errorMessage String?
  checkedAt    DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([checkedAt])
}

model SiteAlertConfig {
  id               String    @id @default(uuid())
  siteId           String    @unique
  alertEmail       String
  onDown           Boolean   @default(true)
  onRecover        Boolean   @default(true)
  cooldownMinutes  Int       @default(60)
  lastAlertSentAt  DateTime?
  webhookUrl       String?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

// ─── Incident Updates (timeline messages) ─────────────────────────────────────

model IncidentUpdate {
  id         String               @id @default(uuid())
  incidentId String
  status     IncidentUpdateStatus
  message    String               @db.Text

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([incidentId])
}

// ─── Status Page ──────────────────────────────────────────────────────────────

model StatusPage {
  id          String  @id @default(uuid())
  userId      String
  slug        String  @unique
  title       String
  description String? @db.Text
  logoUrl     String? @db.Text
  faviconUrl  String? @db.Text
  brandColor  String  @default("#22c55e")
  customCss   String? @db.Text
  isPublic    Boolean @default(true)

  components          StatusPageComponent[]
  scheduledMaintenances ScheduledMaintenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

model StatusPageComponent {
  id           String @id @default(uuid())
  statusPageId String
  siteId       String
  displayName  String
  description  String?
  sortOrder    Int    @default(0)

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)

  @@index([statusPageId])
  @@index([siteId])
}

// ─── Scheduled Maintenance ────────────────────────────────────────────────────

model ScheduledMaintenance {
  id           String            @id @default(uuid())
  statusPageId String
  title        String
  description  String?           @db.Text
  status       MaintenanceStatus @default(SCHEDULED)
  startsAt     DateTime
  endsAt       DateTime

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statusPageId])
}
